# .env.example — mẫu env SHB #132 (COMMIT file này; .env thật GITIGNORED, chứa key thật).
# Copy: cp .env.example .env  → điền key thật → server tự đọc (providers.reload() mỗi spawn).
#
# ── Chọn provider cho SDK runtime (D-45) ────────────────────────────────────
# SHB_PROVIDER = tên provider trong configs/providers.yaml. Bỏ trống = default (claude-cli).
#   claude-cli : subscription — dùng Claude CLI login máy (~/.claude). KHÔNG cần key.
#                Standalone KHÔNG có CLI login → KHÔNG chạy được, phải chọn zai.
#   zai        : keyed z.ai (GLM) — không phụ thuộc CLI auth (dùng cho demo standalone).
# SHB_PROVIDER=zai

# Key cho provider keyed (${tên_biến} trong providers.yaml). Chỉ điền cái đang dùng.
# zai=<z.ai api key>
# ANTHROPIC_API_KEY=<anthropic native key — nếu mở provider anthropic>

# ── DB (đã có ở CLAUDE.md §1; ghi lại cho standalone) ───────────────────────
# DATABASE_URL=postgresql://shb:shb@localhost:5432/shb

# ── Dev (bỏ auth để vào thẳng admin — D-39; KHÔNG bật ở prod) ────────────────
# DEV_SKIP_AUTH=1
# WRAP_API_KEY=<key wrapper psa.team — mở đường GPT models qua provider 'wrap'>

# ── Mail thông báo Gmail (T9-2 D-57) — THIẾU = no-op sạch (log + skip, không lỗi) ────
# Tạo App Password: Google Account → Security → 2-Step Verification (bật) → App passwords →
# chọn "Mail" → copy chuỗi 16 ký tự (bỏ khoảng trắng) vào SMTP_APP_PASSWORD.
# SMTP_USER=<email gmail người gửi, vd shbdigital@gmail.com>
# SMTP_APP_PASSWORD=<16 ký tự App Password — KHÔNG phải mật khẩu Gmail thường>
# NOTIFY_FROM_NAME=SHB Digital
